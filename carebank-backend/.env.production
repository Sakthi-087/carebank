# Production Environment Configuration
# Copy this file to .env and fill in your production values

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Frontend URL (required for CORS)
FRONTEND_URL=https://yourproject.vercel.app

# LLM Configuration (required for AI features)
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=your_openrouter_api_key

# Alternative: Use OpenAI directly (uncomment if using OpenAI instead of OpenRouter)
# OPENAI_API_KEY=your_openai_api_key

# Fallback mode (for Supabase outages)
ENABLE_SAMPLE_DATA_FALLBACK=false
